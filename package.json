{
  "name": "remote-storage-manager",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -w @rsm/shared && npm run build -w @rsm/service && npm run build -w @rsm/client",
    "deploy": "./scripts/deploy.sh",
    "dev:service": "npm run dev -w @rsm/service",
    "dev:client": "npm run dev -w @rsm/client",
    "start:client": "npm run start -w @rsm/client",
    "lint": "npm run -ws lint --if-present",
    "typecheck": "npm run -ws typecheck --if-present"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
